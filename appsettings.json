{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "SecretKey": "", // 用於簽名和驗證的密鑰
    "Issuer": "", // 用於識別發行者，通常是一個 URL 或標識符
    "Audience": "", // 用於識別接收者或目標系統，通常也是一個 URL 或標識符
    "ExpireMinutes": 60 // 定義令牌的過期時間，以分鐘為單位。
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
